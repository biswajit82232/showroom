# Copy to .env.local for local dev (Vite loads .env, .env.local, etc.)
# On Vercel: Project → Settings → Environment Variables (same names, no VITE_ prefix change)

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# If either variable is missing, the app uses browser localStorage only.
