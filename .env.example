# Copy to .env.local for local dev (Vite loads .env, .env.local, etc.)
# On Vercel: Project → Settings → Environment Variables (same variable names)

# Supabase project URL (Dashboard → Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Client key: use the new Publishable key (sb_publishable_…) OR legacy anon JWT
# from Dashboard → API Keys. Never use the secret / service_role key here.
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# If either variable is missing or empty, the app uses browser localStorage only.
